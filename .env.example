DISCORD_TOKEN=your_discord_bot_token_here
WS_PORT=8080
HTTP_PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/kkb_bot
NODE_ENV=development

# Supabase S3-compatible Storage (for GIF uploads)
# Find these in: Supabase Dashboard → Storage → S3 Access Keys
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=your_access_key_id
SUPABASE_S3_SECRET_ACCESS_KEY=your_secret_access_key
SUPABASE_S3_BUCKET=gifs
SUPABASE_S3_REGION=us-east-1
# Your Supabase project URL (for constructing public file URLs)
SUPABASE_PUBLIC_URL=https://<project-ref>.supabase.co
