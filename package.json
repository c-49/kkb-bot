    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lodash-es": "^4.17.21",
    "multer": "^1.4.4",
    "pg": "^8.11.3",
    "sharp": "^0.33.0",
    "ws": "^8.15.0"
  }
}
