{
  "name": "kkb-bot-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Discord bot with dashboard for settings and image management",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:bot": "workspace bot dev",
    "dev:dashboard": "workspace dashboard dev",
    "build": "npm run build -ws",
    "start": "node --enable-source-maps index.js",
